{
  "name": "vektoryum",
  "version": "1.0.0",
  "description": "Vektoryum — Yapay Zekâ ile Vektörleştirme",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "typecheck": "tsc --noEmit --skipLibCheck --esModuleInterop --target es2020 --module nodenext --moduleResolution nodenext server.ts",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "jimp": "^0.22.12",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.19.1",
    "potrace": "^2.1.8",
    "sharp": "^0.33.4",
    "svg-to-pdfkit": "^0.1.8",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^9.0.8",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.6",
    "typescript": "^5.5.2"
  }
}
